{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/MVPuknowme/pnpk-spec/blob/main/extensions/financial-request.schema.json",
  "title": "PNPK Financial Request Extension",
  "description": "Non-executable proof schema for account-holder, bank, and legal-process financial information requests.",
  "type": "object",
  "required": [
    "request_type",
    "jurisdiction",
    "purpose",
    "scope",
    "authorization",
    "execution_authority",
    "funds_movement_requested",
    "retrieval_status"
  ],
  "properties": {
    "request_type": {
      "type": "string",
      "enum": [
        "account_holder_request",
        "bank_request",
        "legal_process_review"
      ]
    },
    "jurisdiction": {
      "type": "string",
      "minLength": 2
    },
    "purpose": {
      "type": "string",
      "minLength": 8
    },
    "scope": {
      "type": "object",
      "required": ["data_types", "account_reference"],
      "properties": {
        "data_types": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "transactions",
              "balances",
              "statements",
              "account_metadata",
              "payment_history",
              "fraud_evidence",
              "legal_process_metadata"
            ]
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "date_from": {
          "type": "string",
          "format": "date"
        },
        "date_to": {
          "type": "string",
          "format": "date"
        },
        "account_reference": {
          "type": "string",
          "description": "Tokenized, hashed, or provider-controlled reference only. Full account numbers are prohibited.",
          "minLength": 8
        }
      },
      "additionalProperties": false
    },
    "authorization": {
      "type": "object",
      "required": ["status"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["verified", "pending", "rejected", "not_applicable"]
        },
        "method_reference": {
          "type": "string"
        },
        "granted_at": {
          "type": "string",
          "format": "date-time"
        },
        "expires_at": {
          "type": "string",
          "format": "date-time"
        },
        "revocable": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "legal_process": {
      "type": "object",
      "properties": {
        "document_present": {
          "type": "boolean"
        },
        "court_or_agency": {
          "type": "string"
        },
        "case_or_reference": {
          "type": "string"
        },
        "validity_status": {
          "type": "string",
          "enum": ["verified", "pending", "rejected", "not_applicable"]
        },
        "service_verified": {
          "type": "boolean"
        },
        "jurisdiction_verified": {
          "type": "boolean"
        },
        "exemptions_reviewed": {
          "type": "boolean"
        },
        "notice_status": {
          "type": "string",
          "enum": ["provided", "pending", "not_applicable"]
        },
        "challenge_window_status": {
          "type": "string",
          "enum": ["open", "expired", "not_applicable", "unknown"]
        },
        "document_hash_reference": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "execution_authority": {
      "const": "none"
    },
    "funds_movement_requested": {
      "const": false
    },
    "retrieval_status": {
      "type": "string",
      "enum": [
        "pending_review",
        "approved_for_read_only_retrieval",
        "blocked",
        "completed_read_only_retrieval"
      ]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "request_type": { "const": "account_holder_request" }
        }
      },
      "then": {
        "properties": {
          "authorization": {
            "properties": {
              "status": { "const": "verified" }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "request_type": { "const": "legal_process_review" }
        }
      },
      "then": {
        "required": ["legal_process"],
        "properties": {
          "legal_process": {
            "required": [
              "document_present",
              "court_or_agency",
              "case_or_reference",
              "validity_status",
              "service_verified",
              "jurisdiction_verified",
              "exemptions_reviewed"
            ],
            "properties": {
              "document_present": { "const": true },
              "validity_status": { "const": "verified" },
              "service_verified": { "const": true },
              "jurisdiction_verified": { "const": true },
              "exemptions_reviewed": { "const": true }
            }
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
